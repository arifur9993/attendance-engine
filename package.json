{
  "name": "attendance-engine-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for attendance-engine — a pure-function workforce time & wage-hour-compliance calculator.",
  "license": "MIT",
  "author": "Md. Arifur Rahman <arifur.rahman210@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/arifur9993/attendance-engine.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "typecheck": "turbo run typecheck",
    "bench": "turbo run bench",
    "lint": "turbo run lint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  }
