{
  "name": "@attendance-engine/core",
  "version": "0.2.1",
  "description": "Pure-function workforce attendance resolver — shifts, breaks, overtime, overnight handling, rosters. Zero dependencies, framework-agnostic.",
  "keywords": [
    "attendance",
    "timesheet",
    "shift",
    "roster",
    "overtime",
    "hr",
    "workforce",
    "payroll",
    "time-tracking",
    "wage-and-hour",
    "compliance",
    "typescript"
  ],
  "license": "MIT",
  "author": "Md. Arifur Rahman <arifur.rahman210@gmail.com>",
  "homepage": "https://github.com/arifur9993/attendance-engine#readme",
  "bugs": {
    "url": "https://github.com/arifur9993/attendance-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arifur9993/attendance-engine.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench --run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.16.13",
    "@vitest/coverage-v8": "^2.1.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
